# AutoResearch Agent System - Environment Configuration

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/autoresearch

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Configuration - OpenAI (default/fallback)
OPENAI_API_KEY=sk-your-openai-key-here

# LLM Configuration - OpenAI Compatible (custom base_url endpoints)
OPENAI_COMPATIBLE_API_KEY=your-api-key
OPENAI_COMPATIBLE_BASE_URL=https://your-custom-endpoint.com/v1
OPENAI_COMPATIBLE_MODEL=gpt-4o

# LLM Configuration - Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# LLM Configuration - Azure OpenAI (optional)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_DEPLOYMENT=gpt-4

# LLM Configuration - Ollama (optional)
OLLAMA_BASE_URL=http://localhost:11434

# ============ Per-Agent LLM Configuration ============
# Each agent can use different providers, models, and API keys
# Providers: openai, openai_compatible, anthropic, azure, ollama
# If not specified, falls back to global LLM settings

# Editor Agent (Chief Orchestrator) - coordinates workflow
# Recommended: Strong reasoning model (e.g., GPT-4, Claude, DeepSeek)
EDITOR_PROVIDER=openai_compatible
EDITOR_API_KEY=your-api-key
EDITOR_BASE_URL=https://your-custom-endpoint.com/v1
EDITOR_MODEL=deepseek-v4-flash
EDITOR_TEMPERATURE=0.7
EDITOR_MAX_TOKENS=16384

# Investigator Agent (Research) - searches and analyzes literature
# Recommended: Good at research and analysis
INVESTIGATOR_PROVIDER=openai_compatible
INVESTIGATOR_API_KEY=your-api-key
INVESTIGATOR_BASE_URL=https://your-custom-endpoint.com/v1
INVESTIGATOR_MODEL=deepseek-v4-flash
INVESTIGATOR_TEMPERATURE=0.7
INVESTIGATOR_MAX_TOKENS=16384

# Writer Agent (Drafting) - writes the document
# Recommended: Good at writing and formatting
WRITER_PROVIDER=openai_compatible
WRITER_API_KEY=your-api-key
WRITER_BASE_URL=https://your-custom-endpoint.com/v1
WRITER_MODEL=deepseek-v4-flash
WRITER_TEMPERATURE=0.7
WRITER_MAX_TOKENS=16384

# Reviewer Agent (Validation) - validates logic and checks plagiarism
# Recommended: Strong analytical and critical thinking
REVIEWER_PROVIDER=openai_compatible
REVIEWER_API_KEY=your-api-key
REVIEWER_BASE_URL=https://your-custom-endpoint.com/v1
REVIEWER_MODEL=deepseek-v4-flash
REVIEWER_TEMPERATURE=0.7
REVIEWER_MAX_TOKENS=16384

# Workspace
WORKSPACE_TEMP_DIR=workspace/temp
WORKSPACE_OUTPUT_DIR=workspace/output

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json